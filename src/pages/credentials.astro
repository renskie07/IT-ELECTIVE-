---
// =============================================================================
// CREDENTIALS PAGE
// =============================================================================
// Displays all certifications and education in a timeline format.
// Data is loaded from: src/data/siteData.ts -> credentials, sectionContent
// =============================================================================

import Layout from "../layouts/Layout.astro";
import TimelineItem from "../components/TimelineItem.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { credentials, sectionContent } from "../data/siteData";
---

<Layout title="Credentials | Tom Joshua">
  <Navbar />

  <!-- Page Header -->
  <div class="pt-32 pb-12 px-6">
    <div class="scroll-fade max-w-6xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
        {sectionContent.education.title}
      </h1>
      <p class="text-neutral-400 max-w-2xl mx-auto text-lg">
        {sectionContent.education.subtitle}
      </p>
    </div>
  </div>

  <!-- Credentials Timeline -->
  <section class="pb-32 relative">
    <div class="max-w-4xl mx-auto px-6">
      <div class="scroll-fade max-w-3xl mx-auto">
        {
          credentials.map((cred, index) => (
            <TimelineItem
              title={cred.title}
              issuer={cred.issuer}
              year={cred.year}
              link={cred.link}
              imagePath={cred.imagePath}
              isLast={index === credentials.length - 1}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Floating Back Button -->
  <a
    href="/"
    class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-50 flex items-center gap-2 px-4 py-2.5 md:px-5 md:py-3 bg-neutral-900/80 backdrop-blur-md border border-white/10 rounded-full text-white shadow-2xl hover:bg-neutral-800 hover:scale-105 transition-all duration-300 group"
  >
    <svg
      class="w-4 h-4 text-neutral-400 group-hover:text-white transition-colors group-hover:-translate-x-1 duration-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    <span class="font-medium">Back to Home</span>
  </a>

  <Footer />
</Layout>
