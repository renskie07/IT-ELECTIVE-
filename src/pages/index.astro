---
// src/pages/index.astro
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BookingButton from "../components/BookingButton.astro";

// CLEAN IMPORT: We pull the data from our external store
// This replaces the big list you had before.
import { projects, services } from "../data/siteData";
const MY_CALENDLY_LINK = "https://calendly.com/tomjatn/30min";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Tom Joshua | BSIT Developer & Technical VA</title>
    <meta name="title" content="Tom Joshua | BSIT Developer & Technical VA" />
    <meta
      name="description"
      content="I bridge the gap between complex code and business operations. A portfolio of technical automation, web development, and system architecture."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tomjoshuas-projects.vercel.app/" />
    <meta
      property="og:title"
      content="Tom Joshua | BSIT Developer & Technical VA"
    />
    <meta
      property="og:description"
      content="BSIT Senior & Technical Virtual Assistant. Specializing in PHP/MySQL, Automation, and System Architecture."
    />
    <meta
      property="og:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://tomjoshuas-projects.vercel.app/"
    />
    <meta
      property="twitter:title"
      content="Tom Joshua | BSIT Developer & Technical VA"
    />
    <meta
      property="twitter:description"
      content="I bridge the gap between complex code and business operations."
    />
    <meta
      property="twitter:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="bg-neutral-950 text-neutral-200 font-sans antialiased selection:bg-blue-500 selection:text-white"
  >
    <header class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="max-w-3xl">
        <span
          class="text-blue-500 font-mono text-sm tracking-wider uppercase mb-4 block"
          >Available for Hire</span
        >
        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-8"
        >
          Technical logic.<br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-teal-400"
          >
            Creative execution.
          </span>
        </h1>
        <p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-2xl">
          I am an IT Specialist & Technical Virtual Assistant. I bridge the gap
          between
          <span class="text-neutral-200 font-medium">complex code</span> and
          <span class="text-neutral-200 font-medium">business operations</span>.
        </p>

        <div class="flex flex-wrap gap-4">
          <BookingButton url={"https://calendly.com/tomjatn/30min"} />

          <a
            href="mailto:tomjatn@gmail.com"
            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full transition-all hover:shadow-lg hover:shadow-blue-500/25"
          >
            Contact Me
          </a>
          <a
            href="#projects"
            class="border border-neutral-700 hover:border-neutral-500 text-neutral-300 font-bold py-3 px-8 rounded-full transition-all"
          >
            My Work
          </a>
        </div>
      </div>
    </header>

    <section class="border-y border-neutral-900/50 bg-neutral-900/20 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-12"
        >
          My Technical Arsenal
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            services.map((service) => (
              <ServiceCard
                title={service.title}
                icon={service.icon}
                description={service.description}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2">
              Selected Projects
            </h2>
            <p class="text-neutral-500">Academic & Client Work</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            projects.map((project) => (
              <ProjectCard
                title={project.title}
                role={project.role}
                status={project.status as "Completed" | "In Progress"}
                description={project.description}
                techStack={project.techStack}
                link={project.link}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <footer class="border-t border-neutral-900 mt-20 bg-neutral-950 py-12">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="text-neutral-600 mb-4">©Copyright 2026</p>
      </div>
    </footer>
  </body>
</html>
