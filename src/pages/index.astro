---
// =============================================================================
// INDEX PAGE (Homepage)
// =============================================================================
// The main landing page of the portfolio.
// Sections: Hero, Tech Stack, Services, Experience, Booking, Footer
// Data is loaded from: src/data/siteData.ts
// =============================================================================

import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";

import TechStack from "../components/TechStack.astro";

import { workExperience, services, sectionContent } from "../data/siteData";
---

<Layout title="Tom Joshua | IT Specialist & Technical VA">
  <Navbar />
  <Hero />
  <TechStack />

  <!-- ===== SERVICES SECTION ===== -->
  <section
    id="services"
    class="py-24 relative bg-neutral-900/30 backdrop-blur-sm border-y border-white/5"
  >
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section Title -->
      <h2
        class="scroll-fade text-sm font-bold text-neutral-500 uppercase tracking-widest mb-12 text-center"
      >
        {sectionContent.services.title}
      </h2>
      <!-- Services Grid -->
      <div class="scroll-fade grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          services.map((service) => (
            <ServiceCard
              title={service.title}
              icon={service.icon}
              description={service.description}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== WORK EXPERIENCE SECTION ===== -->
  <section id="experience" class="py-32 relative">
    <!-- Background Overlay -->
    <div class="absolute inset-0 bg-white/[0.02] -z-10"></div>
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section Header -->
      <div class="scroll-fade mb-20 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {sectionContent.experience.title}
        </h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">
          {sectionContent.experience.subtitle}
        </p>
      </div>

      <!-- Timeline Container -->
      <div class="relative">
        <!-- Vertical Line (Desktop center line) -->
        <div
          class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent -translate-x-1/2"
        >
        </div>

        <!-- Experience Items -->
        <div class="space-y-0">
          {
            workExperience.map((job, index) => (
              <ExperienceItem
                index={index}
                role={job.role}
                company={job.company}
                period={job.period}
                description={job.description}
                skills={job.skills}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
