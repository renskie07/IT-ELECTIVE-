---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import TechStack from "../components/TechStack.astro";
import {
  workExperience,
  services,
  sectionContent,
} from "../data/siteData";
---

<Layout title="Renier C. Nigparanon | 4BSIT-2 Portfolio">
  <Navbar />
  <Hero />

  <section id="about" class="py-24 border-y border-white/5 bg-neutral-900/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid lg:grid-cols-[0.9fr_1.1fr] gap-10 lg:gap-16 items-start">
      <div class="scroll-fade">
        <p class="text-sm font-bold text-emerald-400 uppercase tracking-widest mb-4">
          Profile
        </p>
        <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
          {sectionContent.about.title}
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          {sectionContent.about.description}
        </p>
      </div>

      <div class="scroll-fade grid gap-4">
        {
          sectionContent.about.highlights.map((highlight, index) => (
            <div class="bg-neutral-950/70 border border-white/10 rounded-2xl p-6">
              <div class="text-sm font-mono text-emerald-400 mb-3">
                {(index + 1).toString().padStart(2, "0")}
              </div>
              <p class="text-neutral-300 leading-relaxed">{highlight}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="resume" class="py-24 border-b border-white/5 bg-slate-950/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid lg:grid-cols-[1.15fr_0.85fr] gap-10 items-stretch">
      <div class="scroll-fade rounded-3xl border border-white/10 bg-neutral-900/80 p-8 shadow-2xl">
        <p class="text-sm font-bold text-emerald-400 uppercase tracking-[0.25em] mb-4">
          Resume Snapshot
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-5">
          Student resume built for 4BSIT-2 review.
        </h2>
        <p class="text-neutral-400 leading-relaxed mb-8">
          This portfolio highlights education, professional service roles, and a capstone-ready project showcase with a clean academic presentation.
        </p>

        <div class="grid gap-4">
          <div class="rounded-3xl bg-white/[0.04] border border-white/10 p-6">
            <h3 class="text-sm uppercase tracking-[0.25em] text-emerald-300 mb-3">Education</h3>
            <p class="text-neutral-300 leading-relaxed">BSIT student at New Era University, currently in 4BSIT-2, combining coursework with real-world service work.</p>
          </div>
          <div class="rounded-3xl bg-white/[0.04] border border-white/10 p-6">
            <h3 class="text-sm uppercase tracking-[0.25em] text-emerald-300 mb-3">Experience</h3>
            <p class="text-neutral-300 leading-relaxed">Delivery and event support roles that helped develop communication, coordination, and customer service skills.</p>
          </div>
        </div>
      </div>

      <div class="scroll-fade rounded-3xl border border-white/10 bg-neutral-900/80 p-8 shadow-2xl flex flex-col justify-between">
        <div>
          <p class="text-sm font-bold text-emerald-400 uppercase tracking-[0.25em] mb-4">
            Capstone Focus
          </p>
          <h3 class="text-3xl font-bold text-white mb-5">Capstone portfolio and resume integration</h3>
          <p class="text-neutral-400 leading-relaxed mb-8">
            The capstone section presents a focused student project, while the resume page captures personal work history, schooling, and core skills for future opportunities.
          </p>
        </div>

        <a
          href="/resume"
          class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-bold text-neutral-950 hover:bg-emerald-400 transition-all"
        >
          View Full Resume
        </a>
      </div>
    </div>
  </section>

  <TechStack />

  <section id="services" class="py-24 relative bg-neutral-900/30 border-y border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="scroll-fade text-center max-w-3xl mx-auto mb-12">
        <p class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-4">
          {sectionContent.services.title}
        </p>
        <p class="text-neutral-400 text-lg leading-relaxed">
          {sectionContent.services.subtitle}
        </p>
      </div>

      <div class="scroll-fade grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <ServiceCard
              title={service.title}
              icon={service.icon}
              description={service.description}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section id="experience" class="py-28 relative">
    <div class="absolute inset-0 bg-white/[0.02] -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="scroll-fade mb-16 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {sectionContent.experience.title}
        </h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">
          {sectionContent.experience.subtitle}
        </p>
      </div>

      <div class="relative">
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent -translate-x-1/2"></div>

        <div class="space-y-0">
          {
            workExperience.map((job, index) => (
              <ExperienceItem
                index={index}
                role={job.role}
                company={job.company}
                period={job.period}
                description={job.description}
                skills={job.skills}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
