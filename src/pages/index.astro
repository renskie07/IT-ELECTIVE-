---
// src/pages/index.astro
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BookingButton from "../components/BookingButton.astro";

// CLEAN IMPORT: We pull the data from our external store
import { projects, services } from "../data/siteData";

// Your Calendly Link
const MY_CALENDLY_LINK = "https://calendly.com/tomjatn/30min";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Tom Joshua | IT Specialist & Technical VA</title>
    <meta name="title" content="Tom Joshua | IT Specialist & Technical VA" />
    <meta
      name="description"
      content="I bridge the gap between complex code and business operations. A portfolio of technical automation, web development, and system architecture."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tomjoshuas-projects.vercel.app/" />
    <meta
      property="og:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="og:description"
      content="BSIT Senior & Technical Virtual Assistant. Specializing in PHP/MySQL, Automation, and System Architecture."
    />
    <meta
      property="og:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://tomjoshuas-projects.vercel.app/"
    />
    <meta
      property="twitter:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="twitter:description"
      content="I bridge the gap between complex code and business operations."
    />
    <meta
      property="twitter:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="bg-neutral-950 text-neutral-200 font-sans antialiased selection:bg-blue-500 selection:text-white"
  >
    <header class="max-w-6xl mx-auto px-6 py-20 md:py-32">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span
            class="text-blue-500 font-mono text-sm tracking-wider uppercase mb-4 block"
          >
            Available for Hire
          </span>
          <h1
            class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-8"
          >
            Technical logic.<br />
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-teal-400"
            >
              Creative execution.
            </span>
          </h1>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed">
            I am an <span class="text-white font-bold">IT Specialist</span> & Technical
            Virtual Assistant. I bridge the gap between
            <span class="text-neutral-200 font-medium">complex code</span> and
            <span class="text-neutral-200 font-medium">business operations</span
            >.
          </p>

          <div class="flex flex-wrap gap-4">
            <BookingButton url={MY_CALENDLY_LINK} />

            <a
              href="mailto:tomjatn@gmail.com"
              class="border border-neutral-700 hover:border-neutral-500 text-neutral-300 font-bold py-3 px-8 rounded-full transition-all"
            >
              Contact Me
            </a>
          </div>
        </div>

        <div
          class="relative group order-first md:order-last flex justify-center md:justify-end"
        >
          <div
            class="absolute inset-0 bg-gradient-to-r from-blue-600 to-teal-600 rounded-full blur-2xl opacity-20 group-hover:opacity-50 transition duration-1000 group-hover:duration-200 w-3/4 mx-auto md:mr-0"
          >
          </div>

          <div
            class="relative rounded-2xl bg-neutral-900 border border-neutral-800 overflow-hidden w-64 h-64 md:w-80 md:h-80 shadow-2xl rotate-3 group-hover:rotate-0 transition-all duration-500"
          >
            <img
              src="/public/me.png"
              alt="Tom Joshua"
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500 scale-110 group-hover:scale-100"
            />
          </div>
        </div>
      </div>
    </header>

    <section class="border-y border-neutral-900/50 bg-neutral-900/20 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-12"
        >
          My Technical Arsenal
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            services.map((service) => (
              <ServiceCard
                title={service.title}
                icon={service.icon}
                description={service.description}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2">My Projects</h2>
            <p class="text-neutral-500">Selected Projects & Case Studies</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            projects.map((project) => (
              <ProjectCard
                title={project.title}
                role={project.role}
                status={project.status as "Completed" | "In Progress"}
                description={project.description}
                techStack={project.techStack}
                link={project.link}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <footer class="border-t border-neutral-900 mt-20 bg-neutral-950 py-12">
      <div
        class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6"
      >
        <div class="text-center md:text-left">
          <span class="text-white font-bold text-lg tracking-tight"
            >Tom Joshua.</span
          >
          <p class="text-neutral-600 text-sm mt-1">
            IT Specialist & Technical VA
          </p>
          <p class="text-neutral-700 text-xs mt-4">
            &copy; 2026. All rights reserved.
          </p>
        </div>

        <div class="flex gap-6 items-center">
          <a
            href="https://github.com/ttomon"
            target="_blank"
            class="text-neutral-500 hover:text-white transition-colors duration-300 transform hover:scale-110"
            aria-label="GitHub Profile"
          >
            <svg
              class="w-6 h-6 fill-current"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
          </a>

          <a
            href="https://www.linkedin.com/in/tom-joshua-tumanan-221364315/"
            target="_blank"
            class="text-neutral-500 hover:text-blue-500 transition-colors duration-300 transform hover:scale-110"
            aria-label="LinkedIn Profile"
          >
            <svg
              class="w-6 h-6 fill-current"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>

          <a
            href="mailto:tomjatn@gmail.com"
            class="text-neutral-500 hover:text-teal-400 transition-colors duration-300 transform hover:scale-110"
            aria-label="Email Me"
          >
            <svg
              class="w-6 h-6 fill-current"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
