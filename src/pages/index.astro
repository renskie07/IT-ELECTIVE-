---
// src/pages/index.astro
import ProjectSpotlight from "../components/ProjectSpotlight.astro";
import ServiceCard from "../components/ServiceCard.astro";
import TimelineItem from "../components/TimelineItem.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";

// DATA IMPORT
import { projects, services, credentials } from "../data/siteData";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Tom Joshua | IT Specialist & Technical VA</title>
    <meta name="title" content="Tom Joshua | IT Specialist & Technical VA" />
    <meta
      name="description"
      content="I bridge the gap between complex code and business operations. A portfolio of technical automation, web development, and system architecture."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tomjoshuas-projects.vercel.app/" />
    <meta
      property="og:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="og:description"
      content="BSIT Senior & Technical Virtual Assistant. Specializing in PHP/MySQL, Automation, and System Architecture."
    />
    <meta
      property="og:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://tomjoshuas-projects.vercel.app/"
    />
    <meta
      property="twitter:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="twitter:description"
      content="I bridge the gap between complex code and business operations."
    />
    <meta
      property="twitter:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* Smooth scroll and padding */
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 5rem;
      }

      /* Subtle grid background */
      body {
        background-color: #050505;
        background-image:
          linear-gradient(
            to right,
            rgba(255, 255, 255, 0.015) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.015) 1px,
            transparent 1px
          );
        background-size: 32px 32px;
      }
    </style>
  </head>

  <body
    class="text-neutral-200 font-sans antialiased selection:bg-indigo-500 selection:text-white pt-20"
  >
    <Navbar />
    <Hero />

    <section
      id="services"
      class="py-24 relative bg-neutral-900/30 backdrop-blur-sm border-y border-white/5"
    >
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-12 text-center"
        >
          My Technical Arsenal
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            services.map((service) => (
              <ServiceCard
                title={service.title}
                icon={service.icon}
                description={service.description}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Projects Section: Spotlight Layout -->
    <section id="projects" class="py-32 relative">
      <div class="absolute inset-0 bg-white/[0.02] -z-10"></div>
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-20 text-center">
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
            My Projects
          </h2>
          <p class="text-neutral-400 max-w-2xl mx-auto">
            Selected Projects & Case Studies. Each one solves a specific
            problem.
          </p>
        </div>

        <div class="space-y-12">
          {
            projects.map((project, index) => (
              <ProjectSpotlight
                index={index}
                title={project.title}
                role={project.role}
                status={project.status as "Completed" | "In Progress"}
                description={project.description}
                techStack={project.techStack}
                link={project.link}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Education Section: Timeline Layout -->
    <section
      id="education"
      class="py-24 bg-neutral-900/30 backdrop-blur-sm border-t border-white/5"
    >
      <div class="max-w-4xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-16 text-center"
        >
          Certifications & Education
        </h2>
        <div class="max-w-3xl mx-auto">
          {
            credentials.map((cred, index) => (
              <TimelineItem
                title={cred.title}
                issuer={cred.issuer}
                year={cred.year}
                link={cred.link}
                imagePath={cred.imagePath}
                isLast={index === credentials.length - 1}
              />
            ))
          }
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>
