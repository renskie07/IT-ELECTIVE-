---
// src/pages/index.astro
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CredentialCard from "../components/CredentialCard.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";

// DATA IMPORT
import { projects, services, credentials } from "../data/siteData";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Tom Joshua | IT Specialist & Technical VA</title>
    <meta name="title" content="Tom Joshua | IT Specialist & Technical VA" />
    <meta
      name="description"
      content="I bridge the gap between complex code and business operations. A portfolio of technical automation, web development, and system architecture."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tomjoshuas-projects.vercel.app/" />
    <meta
      property="og:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="og:description"
      content="BSIT Senior & Technical Virtual Assistant. Specializing in PHP/MySQL, Automation, and System Architecture."
    />
    <meta
      property="og:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://tomjoshuas-projects.vercel.app/"
    />
    <meta
      property="twitter:title"
      content="Tom Joshua | IT Specialist & Technical VA"
    />
    <meta
      property="twitter:description"
      content="I bridge the gap between complex code and business operations."
    />
    <meta
      property="twitter:image"
      content="https://tomjoshuas-projects.vercel.app/social-preview.png"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="bg-neutral-950 text-neutral-200 font-sans antialiased selection:bg-blue-500 selection:text-white"
  >
    <Hero />

    <section class="border-y border-neutral-900/50 bg-neutral-900/20 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-12"
        >
          My Technical Arsenal
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            services.map((service) => (
              <ServiceCard
                title={service.title}
                icon={service.icon}
                description={service.description}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-12 border-b border-neutral-900/50">
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-neutral-500 uppercase tracking-widest mb-8"
        >
          Certifications & Education
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            credentials.map((cred) => (
              <CredentialCard
                title={cred.title}
                issuer={cred.issuer}
                year={cred.year}
                link={cred.link}
                imagePath={cred.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="projects"
      class="py-24 bg-neutral-900/20 border-t border-neutral-900/50"
    >
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2">My Projects</h2>
            <p class="text-neutral-500">Selected Projects & Case Studies</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            projects.map((project) => (
              <ProjectCard
                title={project.title}
                role={project.role}
                status={project.status as "Completed" | "In Progress"}
                description={project.description}
                techStack={project.techStack}
                link={project.link}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>
