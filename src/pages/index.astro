---
// src/pages/index.astro
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BookingButton from "../components/BookingButton.astro";

// CLEAN IMPORT: We pull the data from our external store
// This replaces the big list you had before.
import { projects, services } from "../data/siteData";
const MY_CALENDLY_LINK = "https://calendly.com/tomjatn/30min";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>BSIT & Technical VA Portfolio</title>
  </head>
  <body
    class="bg-slate-950 text-slate-200 font-sans antialiased selection:bg-blue-500 selection:text-white"
  >
    <header class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="max-w-3xl">
        <span
          class="text-blue-500 font-mono text-sm tracking-wider uppercase mb-4 block"
          >Available for Hire</span
        >
        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-8"
        >
          Technical logic.<br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-teal-400"
          >
            Creative execution.
          </span>
        </h1>
        <p class="text-xl text-slate-400 mb-10 leading-relaxed max-w-2xl">
          I am a BSIT Senior & Technical Virtual Assistant. I bridge the gap
          between
          <span class="text-slate-200 font-medium">complex code</span> and
          <span class="text-slate-200 font-medium">business operations</span>.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="mailto:your-email@gmail.com"
            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full transition-all hover:shadow-lg hover:shadow-blue-500/25"
          >
            Contact Me
          </a>
          <a
            href="#projects"
            class="border border-slate-700 hover:border-slate-500 text-slate-300 font-bold py-3 px-8 rounded-full transition-all"
          >
            My Work
          </a>
        </div>
      </div>
    </header>

    <section class="border-y border-slate-900/50 bg-slate-900/20 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2
          class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-12"
        >
          My Technical Arsenal
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            services.map((service) => (
              <ServiceCard
                title={service.title}
                icon={service.icon}
                description={service.description}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2">
              Selected Projects
            </h2>
            <p class="text-slate-500">Academic & Client Work</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            projects.map((project) => (
              <ProjectCard
                title={project.title}
                role={project.role}
                status={project.status as "Completed" | "In Progress"}
                description={project.description}
                techStack={project.techStack}
                link={project.link}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </div>
    </section>

    <footer class="border-t border-slate-900 mt-20 bg-slate-950 py-12">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="text-slate-600 mb-4">Built with Astro, Tailwind, & Vercel.</p>
      </div>
    </footer>
  </body>
</html>
