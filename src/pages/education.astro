---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { educationTopics, sectionContent } from "../data/siteData";
---

<Layout
  title="Education | IT Elective 6 | Tom Joshua"
  description={sectionContent.educationPage.description}
>
  <Navbar />

  <section class="pt-28 md:pt-32 pb-12 px-4 sm:px-6">
    <div class="scroll-fade max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <p class="text-sm font-bold text-indigo-300 uppercase tracking-[0.25em] mb-4">
          {sectionContent.educationPage.kicker}
        </p>
        <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
          {sectionContent.educationPage.title}
        </h1>
        <p class="text-neutral-400 text-lg leading-relaxed">
          {sectionContent.educationPage.description}
        </p>
      </div>
    </div>
  </section>

  <section class="pb-24 md:pb-32 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="scroll-fade grid gap-5 md:grid-cols-2">
        {
          educationTopics.map((topic) => (
            <article class="group relative overflow-hidden rounded-lg border border-white/10 bg-neutral-900/70 p-6 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-indigo-400/35 hover:bg-neutral-900">
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-indigo-400/60 to-transparent"></div>
              <div class="flex items-start justify-between gap-5">
                <div class="min-w-0">
                  <span class="mb-4 inline-flex rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] font-mono uppercase tracking-wider text-neutral-400">
                    {topic.tag}
                  </span>
                  <h2 class="text-xl font-bold text-white leading-snug">
                    {topic.title}
                  </h2>
                </div>

                <div class="grid h-12 w-12 shrink-0 place-items-center rounded-lg border border-indigo-400/30 bg-indigo-500/10 text-lg font-extrabold text-indigo-200">
                  {topic.number}
                </div>
              </div>

              <p class="mt-6 text-sm leading-7 text-neutral-300">
                {topic.body}
              </p>

              <div class="mt-6 rounded-lg border border-white/10 bg-white/[0.035] p-4">
                <p class="text-sm leading-6 text-neutral-300">
                  <span class="font-bold text-emerald-300">{topic.calloutLabel}:</span>{" "}
                  {topic.calloutText}
                </p>
              </div>

              <div class="mt-6 flex gap-3 border-t border-white/10 pt-5">
                <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-indigo-400"></span>
                <p class="text-sm leading-7 text-neutral-400">
                  {topic.note}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <a
    href="/"
    class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-50 flex items-center gap-2 px-4 py-2.5 md:px-5 md:py-3 bg-neutral-900/80 backdrop-blur-md border border-white/10 rounded-full text-white shadow-2xl hover:bg-neutral-800 hover:scale-105 transition-all duration-300 group"
  >
    <svg
      class="w-4 h-4 text-neutral-400 group-hover:text-white transition-colors group-hover:-translate-x-1 duration-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    <span class="font-medium">Home</span>
  </a>

  <Footer />
</Layout>
