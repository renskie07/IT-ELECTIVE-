---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { educationTopics, sectionContent } from "../data/siteData";
---

<Layout
  title="Education | IT Elective 6 | Tom Joshua"
  description={sectionContent.educationPage.description}
>
  <Navbar />

  <section class="pt-28 md:pt-32 pb-12 px-4 sm:px-6">
    <div class="scroll-fade max-w-6xl mx-auto">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-bold text-cyan-300 uppercase tracking-[0.25em] mb-4">
            {sectionContent.educationPage.kicker}
          </p>
          <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
            {sectionContent.educationPage.title}
          </h1>
          <p class="text-neutral-400 text-lg leading-relaxed">
            {sectionContent.educationPage.description}
          </p>
        </div>

        <a
          href={sectionContent.educationPage.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center justify-center rounded-full border border-cyan-400/30 bg-cyan-400/10 px-5 py-3 text-sm font-bold text-cyan-200 transition-colors hover:bg-cyan-400/15 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300"
        >
          {sectionContent.educationPage.sourceLabel}
        </a>
      </div>
    </div>
  </section>

  <section class="pb-24 md:pb-32 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="scroll-fade grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          educationTopics.map((topic) => (
            <article class="group flex min-h-[25rem] flex-col overflow-hidden rounded-lg border border-cyan-400/20 bg-[#08111f]/85 shadow-2xl shadow-black/20 transition-colors hover:border-cyan-300/40">
              <div class="border-b border-cyan-400/20 bg-cyan-950/20 px-6 py-5">
                <h2 class="text-base font-extrabold uppercase tracking-wide text-neutral-100">
                  {topic.number} - {topic.title}
                </h2>
              </div>

              <div class="flex flex-1 flex-col p-6">
                <span class="mb-5 w-fit rounded border border-indigo-400/40 bg-indigo-500/10 px-3 py-1 text-[11px] font-mono uppercase tracking-wider text-indigo-300">
                  {topic.tag}
                </span>

                <p class="text-sm leading-7 text-slate-300">
                  {topic.body}
                </p>

                <div class="my-5 border-l border-cyan-300 bg-cyan-950/25 px-4 py-4">
                  <p class="text-sm leading-6 text-slate-300">
                    <span class="font-bold text-cyan-200">{topic.calloutLabel}:</span>{" "}
                    {topic.calloutText}
                  </p>
                </div>

                <p class="mt-auto text-sm leading-7 text-slate-400">
                  {topic.note}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <a
    href="/"
    class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-50 flex items-center gap-2 px-4 py-2.5 md:px-5 md:py-3 bg-neutral-900/80 backdrop-blur-md border border-white/10 rounded-full text-white shadow-2xl hover:bg-neutral-800 hover:scale-105 transition-all duration-300 group"
  >
    <svg
      class="w-4 h-4 text-neutral-400 group-hover:text-white transition-colors group-hover:-translate-x-1 duration-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    <span class="font-medium">Home</span>
  </a>

  <Footer />
</Layout>
