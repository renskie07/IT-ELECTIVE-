---
import Layout from "../layouts/Layout.astro";
import ProjectSpotlight from "../components/ProjectSpotlight.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/siteData";
---

<Layout title="Projects | Tom Joshua">
  <Navbar />

  <div class="pt-32 pb-12 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
        All Projects
      </h1>
      <p class="text-neutral-400 max-w-2xl mx-auto text-lg">
        A deep dive into my technical portfolio. From full-stack applications to
        automation scripts, here is what I've built.
      </p>
    </div>
  </div>

  <section class="pb-32 relative">
    <div class="max-w-6xl mx-auto px-6">
      <div class="space-y-12">
        {
          projects.map((project, index) => (
            <ProjectSpotlight
              index={index}
              title={project.title}
              role={project.role}
              status={project.status as any}
              description={project.description}
              techStack={project.techStack}
              link={project.link}
              imagePath={project.imagePath}
            />
          ))
        }
      </div>
    </div>
  </section>

  {/* Floating Back Button */}
  <a
    href="/"
    class="fixed bottom-8 right-8 z-50 flex items-center gap-2 px-5 py-3 bg-neutral-900/80 backdrop-blur-md border border-white/10 rounded-full text-white shadow-2xl hover:bg-neutral-800 hover:scale-105 transition-all duration-300 group"
  >
    <svg
      class="w-4 h-4 text-neutral-400 group-hover:text-white transition-colors group-hover:-translate-x-1 duration-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    <span class="font-medium">Back to Home</span>
  </a>

  <Footer />
</Layout>
