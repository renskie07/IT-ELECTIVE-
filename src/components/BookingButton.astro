---
// src/components/BookingButton.astro
interface Props {
  url: string; // Your specific Calendly link
  label?: string; // Optional button text
}

const { url, label = "Book a Discovery Call" } = Astro.props;
---

<link
  href="https://assets.calendly.com/assets/external/widget.css"
  rel="stylesheet"
/>

<button
  id="calendly-trigger"
  data-url={url}
  class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3.5 px-8 rounded-full transition-all hover:scale-105 hover:shadow-lg hover:shadow-indigo-500/40 flex items-center gap-2 group"
>
  <span class="group-hover:rotate-12 transition-transform duration-300">📅</span
  >
  {label}
</button>

<script
  is:inline
  src="https://assets.calendly.com/assets/external/widget.js"
  async></script>

<script>
  const button = document.getElementById("calendly-trigger");

  if (button) {
    button.addEventListener("click", (e) => {
      e.preventDefault();
      // @ts-ignore - Calendly is loaded globally by the script above
      Calendly.initPopupWidget({ url: button.dataset.url });
    });
  }
</script>
