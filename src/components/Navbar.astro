---
// src/components/Navbar.astro
const navLinks = [
  { name: "Home", href: "#top" },
  { name: "Services", href: "#services" }, // We will need to add this ID to the section
  { name: "Projects", href: "#projects" },
];
---

<nav class="fixed top-0 w-full z-50 transition-all duration-300" id="navbar">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a
      href="#"
      class="text-xl font-bold text-white tracking-tight hover:text-blue-400 transition-colors"
    >
      Tom Joshua<span class="text-blue-500">.</span>
    </a>

    <div
      class="hidden md:flex gap-8 items-center bg-neutral-900/50 backdrop-blur-md px-6 py-2 rounded-full border border-neutral-800/50"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-neutral-400 hover:text-white transition-colors"
          >
            {link.name}
          </a>
        ))
      }
    </div>

    <a
      href="mailto:tomjatn@gmail.com"
      class="text-sm font-bold bg-white text-black px-4 py-2 rounded-full hover:bg-blue-50 transition-colors"
    >
      Hire Me
    </a>
  </div>
</nav>

<script>
  // Add a scroll effect: When user scrolls down, darken the background
  const nav = document.getElementById("navbar");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add(
        "bg-neutral-950/80",
        "backdrop-blur-lg",
        "border-b",
        "border-neutral-800",
      );
    } else {
      nav?.classList.remove(
        "bg-neutral-950/80",
        "backdrop-blur-lg",
        "border-b",
        "border-neutral-800",
      );
    }
  });
</script>
