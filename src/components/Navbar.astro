---
import { siteConfig, navLinks } from "../data/siteData";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-neutral-950/75 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="min-w-0 group">
      <span class="text-white font-bold text-lg sm:text-xl tracking-tight block truncate">
        {siteConfig.name}
      </span>
      <span class="text-neutral-500 text-[11px] sm:text-xs tracking-wide group-hover:text-neutral-400 transition-colors block truncate">
        {siteConfig.title}
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-neutral-400 hover:text-white focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/60 rounded-sm transition-colors"
          >
            {link.name}
          </a>
        ))
      }
      <a
        href={`mailto:${siteConfig.email}`}
        class="px-5 py-2.5 text-sm font-bold text-neutral-950 bg-white rounded-full hover:bg-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/70 transition-all"
      >
        Contact
      </a>
    </div>

    <div class="md:hidden flex items-center gap-2">
      <a
        href="/projects"
        class="px-3 py-2 text-xs font-semibold text-neutral-300 border border-white/10 rounded-full bg-white/5"
      >
        Projects
      </a>
      <a
        href="/#resume"
        class="px-3 py-2 text-xs font-semibold text-neutral-950 bg-white rounded-full"
      >
        Resume
      </a>
    </div>
  </div>
</nav>
