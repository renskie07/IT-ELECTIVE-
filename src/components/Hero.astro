---
import BookingButton from "./BookingButton.astro";
import { siteConfig } from "../data/siteData";
---

<header class="max-w-6xl mx-auto px-6 py-24 md:py-32 relative overflow-hidden">
  {/* Modern Technical Background Grid */}
  <div
    class="absolute inset-0 pointer-events-none opacity-20 bg-[size:30px_30px] bg-[linear-gradient(to_right,#333_1px,transparent_1px),linear-gradient(to_bottom,#333_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
  >
  </div>

  <div class="grid md:grid-cols-2 gap-16 items-center relative z-10">
    <div>
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-mono tracking-wide uppercase mb-8"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"
          ></span>
        </span>
        Technical Solutions Partner
      </div>

      <h1
        class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-8 leading-tight"
      >
        Engineered for <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-emerald-400"
        >
          Performance.
        </span>
      </h1>

      <p
        class="text-lg md:text-xl text-neutral-400 mb-10 leading-relaxed max-w-lg"
      >
        I architect seamless digital ecosystems. From <span
          class="text-neutral-200 font-medium">high-performance web apps</span
        > to <span class="text-neutral-200 font-medium"
          >automated business logistics</span
        >, I build the technical backbone that allows your business to scale
        without friction.
      </p>

      <div class="flex flex-wrap gap-4">
        <BookingButton url={siteConfig.calendlyUrl} />

        <a
          href={`mailto:${siteConfig.email}`}
          class="group flex items-center gap-3 px-6 py-3.5 rounded-full border border-neutral-700 hover:border-neutral-500 hover:bg-neutral-800 transition-all text-neutral-300 hover:text-white font-medium"
        >
          <span>Get in Touch</span>
          <svg
            class="w-4 h-4 text-neutral-500 group-hover:text-white transition-colors group-hover:translate-x-1 duration-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    <div
      class="relative group order-first md:order-last flex justify-center md:justify-end"
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-blue-600 to-teal-600 rounded-full blur-2xl opacity-20 group-hover:opacity-50 transition duration-1000 group-hover:duration-200 w-3/4 mx-auto md:mr-0"
      >
      </div>
      <div
        class="relative rounded-2xl bg-neutral-900 border border-neutral-800 overflow-hidden w-64 h-64 md:w-80 md:h-80 shadow-2xl rotate-3 group-hover:rotate-0 transition-all duration-500"
      >
        <img
          src="/me.png"
          alt="Tom Joshua"
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500 scale-110 group-hover:scale-100"
        />
      </div>
    </div>
  </div>
</header>
