---
// src/components/CredentialCard.astro
interface Props {
  title: string;
  issuer: string;
  year: string;
  link: string;
  imagePath?: string;
}

const { title, issuer, year, link, imagePath } = Astro.props;
---

<a
  href={link}
  target="_blank"
  class="group flex items-center gap-5 p-5 rounded-2xl bg-neutral-900/30 border border-white/5 hover:border-indigo-500/30 hover:bg-neutral-900/60 transition-all duration-300 relative overflow-hidden backdrop-blur-sm hover:-translate-y-1 hover:shadow-xl"
>
  <div
    class="absolute inset-0 bg-gradient-to-r from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
  >
  </div>

  <div
    class="relative w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden border border-white/10 bg-neutral-800/50 shadow-inner"
  >
    {
      imagePath ? (
        <img
          src={imagePath}
          alt={title}
          class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-all duration-500 group-hover:scale-110"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-2xl">
          📜
        </div>
      )
    }
  </div>

  <div class="relative z-10 flex-grow min-w-0">
    <h3
      class="text-neutral-100 font-bold text-base leading-snug group-hover:text-indigo-300 transition-colors"
    >
      {title}
    </h3>
    <p class="text-neutral-500 text-sm mt-1 font-medium tracking-wide truncate">
      {issuer} • <span class="text-neutral-400 group-hover:text-neutral-300"
        >{year}</span
      >
    </p>
  </div>

  <div class="text-neutral-700 group-hover:text-indigo-400 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
      ></path></svg
    >
  </div>
</a>
