---
// src/components/CredentialCard.astro
interface Props {
  title: string;
  issuer: string;
  year: string;
  icon: string;
}

const { title, issuer, year, icon } = Astro.props;
---

<div
  class="flex items-center gap-4 p-4 rounded-lg bg-neutral-900/50 border border-neutral-800 hover:border-neutral-700 transition-all"
>
  <div
    class="bg-neutral-800 w-12 h-12 flex items-center justify-center rounded-full text-2xl shadow-inner"
  >
    {icon}
  </div>
  <div>
    <h3 class="text-white font-bold text-sm">{title}</h3>
    <p class="text-neutral-500 text-xs mt-0.5">{issuer} • {year}</p>
  </div>
</div>
