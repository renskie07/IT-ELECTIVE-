---
interface Props {
  title: string;
  role: string;
  description: string;
  techStack: string[];
  link?: string;
  imagePath?: string;
  status: "Completed" | "In Progress";
  index: number; // Used for alternating layout
}

const { title, role, description, techStack, link, imagePath, status, index } =
  Astro.props;

const isEven = index % 2 === 0;
const number = (index + 1).toString().padStart(2, "0");
---

<div
  class={`relative flex flex-col md:flex-row gap-8 md:gap-16 items-center py-20 overflow-hidden md:overflow-visible ${!isEven ? "md:flex-row-reverse" : ""}`}
>
  <!-- Connector Line (Desktop Only) -->
  <div
    class="hidden md:block absolute left-1/2 top-40 bottom-[-5rem] w-px bg-gradient-to-b from-indigo-500/0 via-indigo-500/20 to-indigo-500/0 -translate-x-1/2 z-0"
  >
  </div>

  <!-- Image Section -->
  <div class="w-full md:w-1/2 relative group perspective-1000">
    <!-- Tech Corners -->
    <div
      class="absolute -top-2 -left-2 w-8 h-8 border-t-2 border-l-2 border-indigo-500/50 rounded-tl-lg z-20 transition-all group-hover:w-12 group-hover:h-12"
    >
    </div>
    <div
      class="absolute -bottom-2 -right-2 w-8 h-8 border-b-2 border-r-2 border-purple-500/50 rounded-br-lg z-20 transition-all group-hover:w-12 group-hover:h-12"
    >
    </div>

    <!-- Glow Effect -->
    <div
      class="absolute inset-0 bg-indigo-500/20 blur-3xl opacity-20 rounded-full group-hover:opacity-40 transition-opacity duration-500"
    >
    </div>

    <!-- Card -->
    <div
      class="relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/80 backdrop-blur-sm shadow-2xl transition-all duration-700 group-hover:transform group-hover:rotate-y-2 group-hover:scale-[1.02]"
    >
      <div class="aspect-video relative overflow-hidden">
        {
          imagePath ? (
            <img
              src={imagePath}
              alt={title}
              class="w-full h-full object-cover opacity-90 transition-all duration-700 group-hover:scale-110"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-neutral-800/50">
              <span class="text-neutral-700 text-6xl">📷</span>
            </div>
          )
        }
        <!-- Overlay -->
        <div
          class="absolute inset-0 bg-indigo-900/20 group-hover:bg-transparent transition-colors duration-500"
        >
        </div>

        <!-- Status Badge -->
        <div class="absolute top-4 left-4">
          <span
            class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider backdrop-blur-md border shadow-lg ${status === "Completed" ? "bg-emerald-500/20 text-emerald-300 border-emerald-500/30" : "bg-amber-500/20 text-amber-300 border-amber-500/30"}`}
          >
            {status}
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Section -->
  <div class="w-full md:w-1/2 md:px-4 relative z-10">
    <!-- Big Number Watermark -->
    <div
      class={`absolute top-[-3rem] ${isEven ? "right-0 md:right-auto md:left-[-2rem]" : "left-0 md:left-auto md:right-[-2rem]"} text-9xl font-bold text-white/[0.03] select-none pointer-events-none font-outfit`}
    >
      {number}
    </div>

    <span
      class="text-indigo-400 font-mono text-xs tracking-widest uppercase mb-3 flex items-center gap-2"
    >
      <span class="w-8 h-px bg-indigo-500/50"></span>
      {role}
    </span>

    <h3
      class="text-4xl font-bold text-white mb-6 leading-tight group-hover:text-indigo-200 transition-colors"
    >
      {title}
    </h3>

    <p class="text-neutral-400 text-lg leading-relaxed mb-8 relative">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-10">
      {
        techStack.map((tech) => (
          <span class="px-3 py-1.5 text-xs font-medium text-neutral-300 bg-neutral-800/50 border border-white/5 rounded-full hover:bg-white/5 hover:border-indigo-500/30 transition-colors">
            {tech}
          </span>
        ))
      }
    </div>

    {
      link && (
        <a
          href={link}
          target="_blank"
          class="inline-flex items-center gap-3 text-white font-bold group/link bg-white/5 hover:bg-indigo-600 hover:shadow-lg hover:shadow-indigo-500/30 border border-white/10 hover:border-transparent px-6 py-3 rounded-xl transition-all duration-300"
        >
          <span>View Case Study</span>
          <svg
            class="w-4 h-4 group-hover/link:translate-x-1 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            />
          </svg>
        </a>
      )
    }
  </div>
</div>
