---
import type { ProjectStatus } from "../data/siteData";

interface Props {
  title: string;
  role: string;
  description: string;
  problem: string;
  solution: string;
  contributions: string[];
  outcome: string;
  techStack: string[];
  repoUrl: string;
  demoUrl: string;
  imagePath: string;
  imageAlt: string;
  status: ProjectStatus;
  index: number;
}

const {
  title,
  role,
  description,
  problem,
  solution,
  contributions,
  outcome,
  techStack,
  repoUrl,
  demoUrl,
  imagePath,
  imageAlt,
  status,
  index,
} = Astro.props;

const isEven = index % 2 === 0;
const number = (index + 1).toString().padStart(2, "0");
const statusClass =
  status === "Completed"
    ? "bg-emerald-500/20 text-emerald-300 border-emerald-500/30"
    : "bg-amber-500/20 text-amber-300 border-amber-500/30";
---

<article class="relative grid md:grid-cols-2 gap-8 md:gap-14 items-start py-14 md:py-20">
  <div class={`relative group ${!isEven ? "md:order-2" : ""}`}>
    <div class="absolute -top-2 -left-2 w-8 h-8 border-t-2 border-l-2 border-indigo-500/50 rounded-tl-lg z-20"></div>
    <div class="absolute -bottom-2 -right-2 w-8 h-8 border-b-2 border-r-2 border-purple-500/50 rounded-br-lg z-20"></div>

    <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/80 shadow-2xl">
      <div class="aspect-video relative overflow-hidden">
        <img
          src={imagePath}
          alt={imageAlt}
          class="w-full h-full object-cover opacity-95 transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-indigo-950/10"></div>
        <div class="absolute top-4 left-4">
          <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider backdrop-blur-md border shadow-lg ${statusClass}`}>
            {status}
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class={`relative z-10 ${!isEven ? "md:order-1" : ""}`}>
    <div class="absolute -top-8 right-0 text-7xl md:text-9xl font-bold text-white/[0.03] select-none pointer-events-none">
      {number}
    </div>

    <span class="text-indigo-400 font-mono text-xs tracking-widest uppercase mb-3 flex items-center gap-2">
      <span class="w-8 h-px bg-indigo-500/50"></span>
      {role}
    </span>

    <h3 class="text-3xl md:text-4xl font-bold text-white mb-5 leading-tight">
      {title}
    </h3>

    <p class="text-neutral-400 text-lg leading-relaxed mb-8">
      {description}
    </p>

    <div class="grid gap-4 mb-8">
      <div class="rounded-2xl bg-white/[0.03] border border-white/10 p-5">
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-2">
          Problem
        </h4>
        <p class="text-neutral-400 leading-relaxed">{problem}</p>
      </div>
      <div class="rounded-2xl bg-white/[0.03] border border-white/10 p-5">
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-2">
          Solution
        </h4>
        <p class="text-neutral-400 leading-relaxed">{solution}</p>
      </div>
    </div>

    <div class="mb-8">
      <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-3">
        My Contribution
      </h4>
      <ul class="space-y-2">
        {
          contributions.map((item) => (
            <li class="flex gap-3 text-neutral-400">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-indigo-400"></span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mb-8">
      <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-3">
        Outcome
      </h4>
      <p class="text-neutral-400 leading-relaxed">{outcome}</p>
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      {
        techStack.map((tech) => (
          <span class="px-3 py-1.5 text-xs font-medium text-neutral-300 bg-neutral-800/60 border border-white/5 rounded-full">
            {tech}
          </span>
        ))
      }
    </div>

    <div class="flex flex-wrap gap-3">
      {
        repoUrl ? (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center text-white font-bold bg-indigo-600 hover:bg-indigo-500 px-5 py-3 rounded-xl transition-colors"
          >
            Source
          </a>
        ) : (
          <span
            aria-disabled="true"
            class="inline-flex items-center justify-center text-neutral-500 font-bold bg-white/[0.03] border border-white/10 px-5 py-3 rounded-xl cursor-not-allowed"
          >
            Source Coming Soon
          </span>
        )
      }

      {
        demoUrl ? (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center text-white font-bold bg-white/5 hover:bg-neutral-800 border border-white/10 px-5 py-3 rounded-xl transition-colors"
          >
            Live Demo
          </a>
        ) : (
          <span
            aria-disabled="true"
            class="inline-flex items-center justify-center text-neutral-500 font-bold bg-white/[0.03] border border-white/10 px-5 py-3 rounded-xl cursor-not-allowed"
          >
            Demo Coming Soon
          </span>
        )
      }
    </div>
  </div>
</article>
