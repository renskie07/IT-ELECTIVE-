---
interface Props {
  role: string;
  company: string;
  period: string;
  description: string;
  skills: string[];
  index: number;
}

const { role, company, period, description, skills, index } = Astro.props;
const isEven = index % 2 === 0;
const number = (index + 1).toString().padStart(2, "0");
---

<div class={`relative flex flex-col md:flex-row gap-8 md:gap-16 items-start py-12 md:py-16 ${!isEven ? "md:flex-row-reverse" : ""}`}>
  <div class={`absolute top-2 ${isEven ? "right-0 md:left-0" : "left-0 md:right-0"} text-[6rem] md:text-[8rem] leading-none font-bold text-white/[0.03] select-none pointer-events-none -translate-y-1/4`}>
    {number}
  </div>

  <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-white/5 -translate-x-1/2"></div>
  <div class="hidden md:block absolute left-1/2 top-20 w-3 h-3 rounded-full bg-indigo-500 border-4 border-neutral-950 -translate-x-1/2 shadow-[0_0_20px_rgba(99,102,241,0.5)]"></div>
  <div class="hidden md:block w-1/2"></div>

  <div class="w-full md:w-1/2 relative group">
    <div class="relative bg-neutral-900/50 border border-white/5 p-6 md:p-8 rounded-2xl hover:bg-neutral-900 transition-all duration-300 hover:border-indigo-500/20">
      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-6">
        <div>
          <h3 class="text-2xl font-bold text-white group-hover:text-indigo-400 transition-colors">
            {role}
          </h3>
          <p class="text-lg text-indigo-500 font-medium mt-1">{company}</p>
        </div>
        <span class="inline-flex px-4 py-1.5 text-xs font-mono font-bold text-neutral-300 bg-white/5 rounded-full border border-white/10 self-start">
          {period}
        </span>
      </div>

      <p class="text-neutral-400 mb-8 leading-relaxed text-lg border-l-2 border-white/5 pl-4 group-hover:border-indigo-500/30 transition-colors">
        {description}
      </p>

      <div class="flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <span class="px-3 py-1 text-xs font-medium text-neutral-400 bg-neutral-950 border border-white/5 rounded-md group-hover:border-white/10 transition-colors">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</div>
