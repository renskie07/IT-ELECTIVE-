---
// =============================================================================
// BOOKING SECTION COMPONENT
// =============================================================================
// The "Ready to Upgrade?" section with expandable Calendly calendar.
// Content is loaded from: src/data/siteData.ts -> sectionContent.booking
// =============================================================================

import { siteConfig, sectionContent } from "../data/siteData";

const booking = sectionContent.booking;
---

<section id="contact" class="py-32 relative overflow-hidden bg-neutral-950">
  <!-- Background Effects -->
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-900/10 via-neutral-950 to-neutral-950"
  >
  </div>
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
    <!-- Section Heading -->
    <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
      {booking.titleStart}
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400"
        >{booking.titleHighlight}</span
      >
    </h2>

    <!-- Description -->
    <p
      class="text-neutral-400 text-lg md:text-xl mb-12 max-w-xl mx-auto leading-relaxed"
    >
      {booking.description}
    </p>

    <!-- Expandable Calendar Toggle Button -->
    <button
      id="calendar-toggle"
      class="group inline-flex items-center gap-2 md:gap-3 px-5 py-3 md:px-8 md:py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white text-sm md:text-base font-semibold rounded-xl shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transition-all duration-300 transform hover:scale-[1.02] mb-8"
    >
      <!-- Calendar Icon -->
      <svg
        id="calendar-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <!-- Button Text (changes on toggle) -->
      <span id="toggle-text">{booking.buttonOpen}</span>
      <!-- Arrow Icon (rotates on toggle) -->
      <svg
        id="toggle-arrow"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 transition-transform duration-300"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>

    <!-- Calendly Widget Container (Always in DOM, height animated) -->
    <div
      id="calendar-container"
      class="relative group transition-all duration-500 ease-in-out overflow-hidden max-h-0 opacity-0"
    >
      <!-- Glow Effect -->
      <div
        class="absolute -inset-1 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 rounded-2xl opacity-20 blur transition duration-500 group-hover:opacity-40"
      >
      </div>
      <!-- Widget Wrapper -->
      <div
        class="relative bg-neutral-900 border border-white/10 rounded-2xl overflow-hidden shadow-2xl mt-8"
      >
        <div
          id="calendly-widget"
          class="calendly-inline-widget w-full h-[500px] md:h-[700px]"
          data-url={siteConfig.calendlyUrl}
          data-resize="true"
        >
        </div>
      </div>
    </div>

    <!-- Calendly Script -->
    <script
      type="text/javascript"
      src="https://assets.calendly.com/assets/external/widget.js"
      async></script>

    <!-- Toggle Functionality Script -->
    <script
      define:vars={{
        buttonOpen: booking.buttonOpen,
        buttonClose: booking.buttonClose,
      }}
    >
      document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.getElementById("calendar-toggle");
        const calendarContainer = document.getElementById("calendar-container");
        const toggleText = document.getElementById("toggle-text");
        const toggleArrow = document.getElementById("toggle-arrow");

        if (!toggleBtn || !calendarContainer || !toggleText || !toggleArrow)
          return;

        let isExpanded = false;

        toggleBtn.addEventListener("click", function () {
          isExpanded = !isExpanded;

          if (isExpanded) {
            calendarContainer.classList.remove("max-h-0", "opacity-0");
            calendarContainer.classList.add("max-h-[800px]", "opacity-100");
            toggleText.textContent = buttonClose;
            toggleArrow.style.transform = "rotate(180deg)";
          } else {
            calendarContainer.classList.remove("max-h-[800px]", "opacity-100");
            calendarContainer.classList.add("max-h-0", "opacity-0");
            toggleText.textContent = buttonOpen;
            toggleArrow.style.transform = "rotate(0deg)";
          }
        });
      });
    </script>
  </div>
</section>
