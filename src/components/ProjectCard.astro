---
// src/components/ProjectCard.astro
interface Props {
  title: string;
  role: string;
  description: string;
  techStack: string[];
  link?: string;
  imagePath?: string; // New optional property for images
  status: "Completed" | "In Progress";
}

const { title, role, description, techStack, link, imagePath, status } =
  Astro.props;
---

<div
  class="group bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-900/20"
>
  <div class="h-48 overflow-hidden bg-slate-800 relative">
    {
      imagePath ? (
        <img
          src={imagePath}
          alt={title}
          class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
        />
      ) : (
        /* Fallback if no image is provided */
        <div class="w-full h-full flex items-center justify-center bg-slate-800">
          <span class="text-slate-600 text-4xl">📷</span>
        </div>
      )
    }

    <div class="absolute top-4 right-4">
      <span
        class={`px-3 py-1 rounded-full text-xs font-bold shadow-lg ${status === "Completed" ? "bg-green-500/90 text-white" : "bg-yellow-500/90 text-black"}`}
      >
        {status}
      </span>
    </div>
  </div>

  <div class="p-6">
    <div class="mb-4">
      <h3 class="text-2xl font-bold text-white mb-1">{title}</h3>
      <span class="text-sm text-blue-400 font-mono">{role}</span>
    </div>

    <p class="text-slate-400 text-sm mb-6 leading-relaxed h-20 overflow-hidden">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {
        techStack.map((tech) => (
          <span class="bg-slate-800 text-slate-300 text-xs px-2 py-1 rounded border border-slate-700">
            {tech}
          </span>
        ))
      }
    </div>

    {
      link && (
        <a
          href={link}
          class="inline-flex items-center text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-bold transition-colors w-full justify-center"
        >
          View Case Study
        </a>
      )
    }
  </div>
</div>
