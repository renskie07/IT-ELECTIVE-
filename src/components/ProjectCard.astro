---
// src/components/ProjectCard.astro
interface Props {
  title: string;
  role: string;
  description: string;
  techStack: string[];
  link?: string;
  imagePath?: string; // New optional property for images
  status: "Completed" | "In Progress";
}

const { title, role, description, techStack, link, imagePath, status } =
  Astro.props;
---

<div
  class="group relative rounded-2xl bg-neutral-900/40 border border-white/5 backdrop-blur-sm overflow-hidden hover:border-indigo-500/30 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/20 hover:-translate-y-2"
>
  <div class="h-56 overflow-hidden bg-neutral-900 relative">
    {
      imagePath ? (
        <img
          src={imagePath}
          alt={title}
          class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700 ease-out"
        />
      ) : (
        /* Fallback if no image is provided */
        <div class="w-full h-full flex items-center justify-center bg-neutral-800/50">
          <span class="text-neutral-700 text-4xl">📷</span>
        </div>
      )
    }

    <div class="absolute top-4 right-4 z-10">
      <span
        class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-lg backdrop-blur-md border border-white/10 ${status === "Completed" ? "bg-emerald-500/20 text-emerald-300 border-emerald-500/20" : "bg-amber-500/20 text-amber-300 border-amber-500/20"}`}
      >
        {status}
      </span>
    </div>

    <!-- Gradient overlay for text readability on image if needed, or just style -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/40 to-transparent opacity-60"
    >
    </div>
  </div>

  <div class="p-8 relative">
    <div class="mb-4">
      <h3 class="text-2xl font-bold text-white mb-2 leading-tight">{title}</h3>
      <span
        class="text-xs font-semibold tracking-widest text-indigo-400 uppercase"
        >{role}</span
      >
    </div>

    <p
      class="text-neutral-400 text-sm mb-6 leading-relaxed h-16 overflow-hidden line-clamp-3"
    >
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-8">
      {
        techStack.map((tech) => (
          <span class="bg-white/5 hover:bg-white/10 text-neutral-300 text-[11px] font-medium px-2.5 py-1 rounded-md border border-white/5 transition-colors">
            {tech}
          </span>
        ))
      }
    </div>

    {
      link && (
        <a
          href={link}
          class="inline-flex items-center gap-2 text-white bg-indigo-600 hover:bg-indigo-500 px-6 py-3 rounded-xl text-sm font-bold transition-all w-full justify-center shadow-lg shadow-indigo-900/20 hover:shadow-indigo-500/40"
        >
          View Case Study
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14 5l7 7m0 0l-7 7m7-7H3"
            />
          </svg>
        </a>
      )
    }
  </div>
</div>
