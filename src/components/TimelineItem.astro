---
// =============================================================================
// TIMELINE ITEM COMPONENT
// =============================================================================
// Displays a single credential entry in an alternating timeline layout.
// Used in: src/pages/credentials.astro
// Props: title, issuer, year, link, imagePath, index (for alternation), isLast
// Data source: src/data/siteData.ts -> credentials
// =============================================================================

interface Props {
  title: string;
  issuer: string;
  year: string;
  link: string;
  imagePath?: string;
  index: number; // Controls left/right alternation (even = left, odd = right)
  isLast?: boolean; // Currently unused, kept for future use
}

const {
  title,
  issuer,
  year,
  link,
  imagePath,
  index,
  isLast = false,
} = Astro.props;
const isEven = index % 2 === 0;
---

<div
  class={`relative flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-0 ${isEven ? "md:flex-row" : "md:flex-row-reverse"} mb-16 md:mb-24 last:mb-0 group`}
>
  <!-- Content Side (Card) -->
  <div class="w-full pl-12 md:pl-0 md:w-1/2 md:px-12 relative perspective-1000">
    <a
      href={link}
      target="_blank"
      class="block group/card transition-transform duration-500 hover:scale-[1.02]"
    >
      <!-- Card Container (Glassmorphic Certificate Style) -->
      <div
        class={`
          relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/90 backdrop-blur-xl
          shadow-lg transition-all duration-500
          group-hover/card:border-indigo-500/30 group-hover/card:shadow-2xl group-hover/card:shadow-indigo-500/10
          ${isEven ? "origin-right" : "origin-left"}
        `}
      >
        <!-- Card Glow -->
        <div
          class="absolute -inset-1 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 opacity-0 group-hover/card:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>

        <div
          class="relative p-6 md:p-8 flex flex-col sm:flex-row gap-6 items-center sm:items-start text-center sm:text-left z-10"
        >
          <!-- Credential Icon/Image -->
          <div class="flex-shrink-0 relative">
            <div
              class="w-20 h-20 rounded-xl bg-gradient-to-br from-neutral-800 to-neutral-900 border border-white/10 p-4 flex items-center justify-center shadow-inner group-hover/card:scale-105 transition-transform duration-500"
            >
              {
                imagePath ? (
                  <img
                    src={imagePath}
                    alt={title}
                    class="w-full h-full object-contain opacity-80 group-hover/card:opacity-100 transition-opacity"
                  />
                ) : (
                  <span class="text-4xl">🏅</span>
                )
              }
            </div>
          </div>

          <!-- Content Details -->
          <div class="flex-grow pt-1 min-w-0">
            <h3
              class="text-xl md:text-2xl font-bold text-white mb-2 leading-tight group-hover/card:text-indigo-200 transition-colors pr-16 md:pr-20"
            >
              {title}
            </h3>

            <p
              class="text-neutral-400 font-medium mb-4 flex items-center justify-center sm:justify-start gap-2"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
              {issuer}
            </p>

            <div
              class="inline-flex items-center gap-2 text-sm text-indigo-400 group-hover/card:text-indigo-300 transition-colors font-medium"
            >
              View Credential
              <svg
                class="w-4 h-4 transform group-hover/card:translate-x-1 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>

    <!-- Horizontal Connector Line (Desktop) -->
    <div
      class={`hidden md:block absolute top-1/2 w-12 h-px bg-gradient-to-r from-indigo-500/20 to-transparent -z-10 ${isEven ? "right-0 bg-gradient-to-l" : "left-0 bg-gradient-to-r"}`}
    >
    </div>
  </div>

  <!-- Center Marker (Desktop) -->
  <div
    class="absolute left-1/2 top-1/2 -translate-y-1/2 -translate-x-1/2 hidden md:flex items-center justify-center z-10"
  >
    <div
      class="w-4 h-4 rounded-full bg-neutral-900 border-2 border-indigo-500 relative group-hover:scale-150 transition-transform duration-500 shadow-[0_0_0_4px_rgba(10,10,10,1)]"
    >
      <div
        class="absolute inset-0 bg-indigo-500 rounded-full animate-ping opacity-0 group-hover:opacity-50"
      >
      </div>
    </div>
  </div>

  <!-- Mobile Timeline Line (Absolute Left) -->
  <div
    class="absolute left-4 top-0 bottom-0 w-px bg-neutral-800 md:hidden -z-10"
  >
  </div>
  <!-- Mobile Dot -->
  <div
    class="absolute left-[0.85rem] top-8 w-3 h-3 rounded-full bg-indigo-500 md:hidden shadow-[0_0_0_4px_rgba(23,23,23,1)] z-10"
  >
  </div>

  <!-- Year Side (Desktop) -->
  <div
    class={`w-full md:w-1/2 md:px-12 flex flex-col justify-center items-center mt-4 md:mt-0 pointer-events-none`}
  >
    <div class="hidden md:block relative w-full">
      <span
        class="text-8xl font-bold text-white/10 select-none font-outfit absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 scale-150 pointer-events-none whitespace-nowrap"
      >
        {year}
      </span>
    </div>

    <!-- Mobile Year -->
    <span
      class="md:hidden absolute top-[-2rem] right-0 text-5xl font-bold text-white/[0.05]"
      >{year}</span
    >
  </div>
</div>
