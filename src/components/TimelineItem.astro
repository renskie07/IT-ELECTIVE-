---
interface Props {
  title: string;
  issuer: string;
  year: string;
  link: string;
  imagePath?: string;
  index: number;
}

const { title, issuer, year, link, imagePath, index } = Astro.props;
const isEven = index % 2 === 0;
---

<div
  class={`relative flex flex-col md:flex-row items-stretch gap-6 md:gap-0 ${isEven ? "md:flex-row" : "md:flex-row-reverse"} mb-12 md:mb-20 last:mb-0 group`}
>
  <div class="w-full md:w-1/2 md:px-12 relative">
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="block group/card transition-transform duration-300 hover:scale-[1.01] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/60 rounded-2xl"
    >
      <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/90 shadow-lg transition-all duration-300 group-hover/card:border-indigo-500/30">
        <div class="relative p-6 md:p-8 flex flex-col sm:flex-row gap-6 items-center sm:items-start text-center sm:text-left z-10">
          <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-gradient-to-br from-neutral-800 to-neutral-900 border border-white/10 p-4 flex items-center justify-center shadow-inner">
            {
              imagePath ? (
                <img
                  src={imagePath}
                  alt={title}
                  class="w-full h-full object-contain opacity-90"
                />
              ) : (
                <span class="text-sm font-bold text-indigo-300">{year}</span>
              )
            }
          </div>

          <div class="flex-grow pt-1 min-w-0">
            <div class="text-sm font-mono text-indigo-400 mb-2">{year}</div>
            <h3 class="text-xl md:text-2xl font-bold text-white mb-2 leading-tight group-hover/card:text-indigo-200 transition-colors">
              {title}
            </h3>

            <p class="text-neutral-400 font-medium mb-4">
              {issuer}
            </p>

            <div class="inline-flex items-center gap-2 text-sm text-indigo-400 group-hover/card:text-indigo-300 transition-colors font-medium">
              View Credential
              <svg
                class="w-4 h-4 transform group-hover/card:translate-x-1 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>

  <div class="hidden md:flex w-1/2 md:px-12 items-center justify-center pointer-events-none">
    <span class="text-7xl font-bold text-white/10 select-none">
      {year}
    </span>
  </div>

  <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-y-1/2 -translate-x-1/2 items-center justify-center z-10">
    <div class="w-4 h-4 rounded-full bg-neutral-900 border-2 border-indigo-500 shadow-[0_0_0_4px_rgba(10,10,10,1)]"></div>
  </div>
</div>
