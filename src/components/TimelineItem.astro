---
// =============================================================================
// TIMELINE ITEM COMPONENT
// =============================================================================
// Displays a single credential/certification entry in a timeline layout.
// Props: title, issuer, year, link, imagePath (optional), isLast
// Data source: src/data/siteData.ts -> credentials
// =============================================================================

interface Props {
  title: string;
  issuer: string;
  year: string;
  link: string;
  imagePath?: string;
  isLast?: boolean;
}

const { title, issuer, year, link, imagePath, isLast = false } = Astro.props;
---

<div class="relative pl-8 md:pl-0">
  <!-- Timeline Line (Mobile: Left side) -->
  <div
    class={`absolute left-0 top-0 w-px bg-neutral-800 md:hidden ${isLast ? "bottom-[-3rem] bg-gradient-to-b from-neutral-800 to-transparent" : "bottom-0"}`}
  >
  </div>

  <div class="flex flex-col md:flex-row gap-8 group relative">
    <!-- Year Section (Desktop: Left side) -->
    <div class="hidden md:flex md:w-32 flex-col items-end pt-1">
      <span
        class="text-2xl font-bold text-neutral-600 group-hover:text-indigo-400 transition-colors"
        >{year}</span
      >
    </div>

    <!-- Timeline Dot -->
    <div
      class="absolute left-[-5px] top-2 md:left-[8.5rem] w-3 h-3 rounded-full bg-neutral-800 border border-indigo-500/50 group-hover:bg-indigo-500 group-hover:scale-125 transition-all duration-300 shadow-[0_0_0_4px_rgba(0,0,0,1)] z-10"
    >
      <!-- Ping Animation (on hover) -->
      <div
        class="absolute inset-0 rounded-full bg-indigo-400/50 animate-ping opacity-0 group-hover:opacity-100"
      >
      </div>
    </div>

    <!-- Timeline Connector Line (Desktop: Vertical) -->
    <div
      class={`hidden md:block absolute left-[8.85rem] top-4 w-px bg-gradient-to-b from-indigo-500/50 to-neutral-800 -z-0 ${isLast ? "bottom-[-6rem] bg-gradient-to-b from-neutral-800 via-neutral-800/50 to-transparent" : "bottom-[-3rem]"}`}
    >
    </div>

    <!-- Content Card -->
    <div class="flex-1 pb-12">
      <a
        href={link}
        target="_blank"
        class="block p-1 rounded-2xl bg-gradient-to-br from-white/10 to-transparent hover:from-indigo-500/30 transition-all duration-300 group/card"
      >
        <div
          class="relative p-6 rounded-xl bg-neutral-900/90 backdrop-blur-md border border-white/5 h-full overflow-hidden"
        >
          <!-- Decorative Watermark Emoji -->
          <div
            class="absolute -right-4 -top-4 text-9xl opacity-[0.03] rotate-12 select-none pointer-events-none grayscale"
          >
            🎓
          </div>

          <div class="flex flex-col sm:flex-row gap-6 relative z-10">
            <!-- Credential Icon/Image -->
            <div
              class="w-16 h-16 rounded-xl bg-gradient-to-br from-neutral-800 to-neutral-900 border border-white/10 p-3 flex-shrink-0 shadow-inner flex items-center justify-center group-hover/card:scale-110 transition-transform duration-500"
            >
              {
                imagePath ? (
                  <img
                    src={imagePath}
                    alt={title}
                    class="w-full h-full object-contain opacity-80 group-hover/card:opacity-100 transition-opacity"
                  />
                ) : (
                  <div class="text-2xl">🏅</div>
                )
              }
            </div>

            <!-- Credential Details -->
            <div class="flex-grow">
              <div class="flex items-center justify-between mb-1">
                <!-- Year (Mobile only) -->
                <span class="md:hidden text-xs font-bold text-indigo-400 block"
                  >{year}</span
                >
                <!-- Verified Badge -->
                <span
                  class="hidden md:inline-flex px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-white/5 text-neutral-400 border border-white/5"
                  >Verified Credential</span
                >
              </div>

              <!-- Title -->
              <h4
                class="text-xl font-bold text-white group-hover/card:text-indigo-200 transition-colors mb-1"
              >
                {title}
              </h4>

              <!-- Issuer -->
              <p
                class="text-neutral-400 text-sm font-medium flex items-center gap-2"
              >
                <span class="w-2 h-2 rounded-full bg-indigo-500/50"></span>
                {issuer}
              </p>
            </div>

            <!-- External Link Arrow -->
            <div class="self-center sm:self-start">
              <div
                class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-neutral-400 group-hover/card:bg-indigo-600 group-hover/card:text-white transition-all duration-300 transform group-hover/card:rotate-45"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path></svg
                >
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>
