  freelancer: `<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.096 3.076l1.634 2.292L24 3.076M5.503 20.924l4.474-4.374-2.692-2.89m6.133-10.584L6.905 8.5h5.166l-1.453 2.916 4.74 5.027 1.106-4.18h3.64l-4.472 7.738 1.478 1.078L24 7.07H13.272"></path></svg>`,
};

const activeLinks = [
  { label: "Source Code", href: siteConfig.social.github, icon: icons.github },
  { label: "LinkedIn", href: siteConfig.social.linkedin, icon: icons.linkedin },
  { label: "Facebook", href: siteConfig.social.facebook, icon: icons.facebook },
  { label: "Email", href: `mailto:${siteConfig.email}`, icon: icons.email },
].filter((link) => link.href);

const disabledIconByName: Record<string, string> = {
  Upwork: icons.upwork,
  Fiverr: icons.fiverr,
  Freelancer: icons.freelancer,
};
---

<footer class="relative border-t border-white/5 bg-neutral-900/40 backdrop-blur-md pt-20 pb-10 overflow-hidden">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-emerald-500/10 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="grid md:grid-cols-[1fr_1.1fr] gap-12 mb-16 items-start">
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {footer.ctaLine1}
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
            {footer.ctaLine2}
          </span>
        </h2>
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center gap-2 bg-white text-neutral-950 font-bold px-8 py-4 rounded-full hover:bg-neutral-200 transition-colors shadow-lg shadow-white/5"
        >
          {footer.ctaButton}
        </a>
      </div>

      <div>
        <span class="block text-neutral-400 text-sm font-mono uppercase tracking-widest mb-6 text-center md:text-right">
          {footer.connectLabel}
        </span>

        <div class="flex flex-wrap justify-center md:justify-end gap-3 mb-5">
          {
            activeLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
                aria-label={link.label}
                title={link.label}
                class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/70 transition-all duration-300"
                set:html={link.icon}
              >
              </a>
            ))
          }
          {
            freelancePlatforms.map((platform) => (
              <span
                role="link"
                aria-disabled="true"
                aria-label={`${platform.name} profile ${platform.status}`}
                title={`${platform.name}: ${platform.status}`}
                class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/[0.03] border border-white/10 text-neutral-600 opacity-60 grayscale cursor-not-allowed"
                set:html={disabledIconByName[platform.name]}
              >
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex justify-center text-center">
      <p class="text-neutral-600 text-xs">
        &copy; {currentYear} {footer.copyright}
      </p>
    </div>
  </div>
</footer>
