---
const currentYear = new Date().getFullYear();
---

<footer
  class="relative border-t border-white/5 bg-neutral-900/40 backdrop-blur-md pt-20 pb-10 overflow-hidden"
>
  <!-- Aurora Glow -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-indigo-600/10 blur-[100px] rounded-full pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-12 mb-16"
    >
      <!-- CTA Section -->
      <div class="text-center md:text-left">
        <h2
          class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight"
        >
          Let's Build Something <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400"
            >Extraordinary.</span
          >
        </h2>
        <a
          href="mailto:tomjatn@gmail.com"
          class="inline-flex items-center gap-2 bg-white text-neutral-950 font-bold px-8 py-4 rounded-full hover:bg-neutral-200 transition-colors shadow-lg shadow-white/5"
        >
          Start a Project
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
      </div>

      <!-- Social Links -->
      <div>
        <span
          class="block text-neutral-400 text-sm font-mono uppercase tracking-widest mb-6 text-center md:text-right"
          >Connect</span
        >
        <div class="flex gap-4">
          <a
            href="https://github.com/ttomon"
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
          </a>
          <a
            href="https://www.linkedin.com/in/tom-joshua-tumanan-221364315/"
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
          <a
            href="mailto:tomjatn@gmail.com"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <div
      class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-center items-center gap-4 text-center"
    >
      <p class="text-neutral-600 text-xs">
        &copy; {currentYear} All Rights Reserved.
      </p>
    </div>
  </div>
</footer>
