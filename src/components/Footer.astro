---
// =============================================================================
// FOOTER COMPONENT
// =============================================================================
// The site footer with CTA, social links, and copyright.
// Content is loaded from: src/data/siteData.ts -> sectionContent.footer
// =============================================================================

import { siteConfig, sectionContent } from "../data/siteData";

const footer = sectionContent.footer;
const currentYear = new Date().getFullYear();
---

<footer
  class="relative border-t border-white/5 bg-neutral-900/40 backdrop-blur-md pt-20 pb-10 overflow-hidden"
>
  <!-- Aurora Glow Background Effect -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-indigo-600/10 blur-[100px] rounded-full pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-12 mb-16"
    >
      <!-- CTA Section -->
      <div class="text-center md:text-left">
        <h2
          class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight"
        >
          {footer.ctaLine1}
          <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400"
            >{footer.ctaLine2}</span
          >
        </h2>
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center gap-2 bg-white text-neutral-950 font-bold px-8 py-4 rounded-full hover:bg-neutral-200 transition-colors shadow-lg shadow-white/5"
        >
          {footer.ctaButton}
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
      </div>

      <!-- Social Links Section -->
      <div>
        <span
          class="block text-neutral-400 text-sm font-mono uppercase tracking-widest mb-6 text-center md:text-right"
          >{footer.connectLabel}</span
        >
        <div class="flex gap-4">
          <!-- GitHub -->
          <a
            href={siteConfig.social.github}
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
            aria-label="GitHub Profile"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
          </a>
          <!-- LinkedIn -->
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
            aria-label="LinkedIn Profile"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
          <!-- Email -->
          <a
            href={`mailto:${siteConfig.email}`}
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-indigo-500/50 hover:text-indigo-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-300"
            aria-label="Send Email"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"
              ></path></svg
            >
          </a>
          <!-- Upwork -->
          <a
            href={siteConfig.social.upwork}
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-emerald-500/50 hover:text-emerald-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-emerald-500/20 transition-all duration-300"
            aria-label="Upwork Profile"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"
              ></path></svg
            >
          </a>
          <!-- Fiverr -->
          <a
            href={siteConfig.social.fiverr}
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-emerald-500/50 hover:text-emerald-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-emerald-500/20 transition-all duration-300"
            aria-label="Fiverr Profile"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M23.004 15.588a.995.995 0 1 0 .002-1.99.995.995 0 0 0-.002 1.99zm-.996-3.705h-.85c-.546 0-.84.41-.84 1.092v2.466h-1.61v-3.558h-.684c-.547 0-.84.41-.84 1.092v2.466h-1.61V11.89h1.61v.74a1.28 1.28 0 0 1 1.2-.74h1.453v.74a1.28 1.28 0 0 1 1.2-.74h.971v.993zm-6.093 2.559a.898.898 0 0 1-.634-.238l.003-.003-.002.005a.877.877 0 0 1-.249-.618.882.882 0 0 1 .252-.631.866.866 0 0 1 .63-.247.88.88 0 0 1 .638.247.896.896 0 0 1 .248.63.87.87 0 0 1-.247.619.876.876 0 0 1-.639.236zm-.003-4.268a2.553 2.553 0 0 0-1.795.718 2.475 2.475 0 0 0-.739 1.803c.003.679.27 1.33.743 1.804a2.556 2.556 0 0 0 1.79.718 2.546 2.546 0 0 0 1.793-.72 2.485 2.485 0 0 0 .74-1.802 2.47 2.47 0 0 0-.74-1.803 2.55 2.55 0 0 0-1.792-.718zM9.34 15.441h1.61v-5.407H9.34v5.407zm.769-6.426a.89.89 0 0 0 .636-.24.88.88 0 0 0 .247-.617.894.894 0 0 0-.883-.879.895.895 0 0 0-.638.242.882.882 0 0 0-.247.635.87.87 0 0 0 .246.618.878.878 0 0 0 .639.241zM7.194 11.89h-.85c-.546 0-.84.41-.84 1.092v2.466H3.893v-3.558h-.683c-.547 0-.84.41-.84 1.092v2.466H.76V10.034h1.61v.74c.256-.444.73-.74 1.199-.74h1.453v.74c.256-.444.73-.74 1.199-.74h.972v1.856z"
              ></path></svg
            >
          </a>
          <!-- Freelancer -->
          <a
            href={siteConfig.social.freelancer}
            target="_blank"
            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white hover:bg-neutral-900 hover:border-blue-500/50 hover:text-blue-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300"
            aria-label="Freelancer Profile"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"
              ><path
                d="M14.096 3.076l1.634 2.292L24 3.076M5.503 20.924l4.474-4.374-2.692-2.89m6.133-10.584L6.905 8.5h5.166l-1.453 2.916 4.74 5.027 1.106-4.18h3.64l-4.472 7.738 1.478 1.078L24 7.07H13.272"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div
    class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-center items-center gap-4 text-center"
  >
    <p class="text-neutral-600 text-xs">
      &copy; {currentYear}
      {footer.copyright}
    </p>
  </div>
</footer>
