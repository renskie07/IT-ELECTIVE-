---
import {
  freelancePlatforms,
  siteConfig,
  sectionContent,
} from "../data/siteData";

const footer = sectionContent.footer;
const currentYear = new Date().getFullYear();

const activeLinks = [
  { label: "Source Code", href: siteConfig.social.github },
  { label: "LinkedIn", href: siteConfig.social.linkedin },
  { label: "Email", href: `mailto:${siteConfig.email}` },
];
---

<footer class="relative border-t border-white/5 bg-neutral-900/40 backdrop-blur-md pt-20 pb-10 overflow-hidden">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-indigo-600/10 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="grid md:grid-cols-[1fr_1.1fr] gap-12 mb-16 items-start">
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {footer.ctaLine1}
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
            {footer.ctaLine2}
          </span>
        </h2>
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center gap-2 bg-white text-neutral-950 font-bold px-8 py-4 rounded-full hover:bg-neutral-200 transition-colors shadow-lg shadow-white/5"
        >
          {footer.ctaButton}
        </a>
      </div>

      <div>
        <span class="block text-neutral-400 text-sm font-mono uppercase tracking-widest mb-6 text-center md:text-right">
          {footer.connectLabel}
        </span>

        <div class="grid sm:grid-cols-3 gap-3 mb-6">
          {
            activeLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
                class="text-center rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm font-semibold text-neutral-200 hover:text-white hover:border-indigo-500/40 hover:bg-white/10 transition-colors"
              >
                {link.label}
              </a>
            ))
          }
        </div>

        <div class="flex flex-wrap justify-center md:justify-end gap-2">
          {
            freelancePlatforms.map((platform) => (
              <span
                aria-disabled="true"
                class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-neutral-500 cursor-not-allowed"
              >
                {platform.name}: {platform.status}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex justify-center text-center">
      <p class="text-neutral-600 text-xs">
        &copy; {currentYear} {footer.copyright}
      </p>
    </div>
  </div>
</footer>
