---
// =============================================================================
// TECH STACK COMPONENT
// =============================================================================
// Displays technologies & tools organized by category with stats and trust badges.
// Content is loaded from: src/data/siteData.ts -> techStack, stats, trustPlatforms
// =============================================================================

import {
  techStack,
  sectionContent,
  stats,
  trustPlatforms,
} from "../data/siteData";

// Icon SVGs for each category
const categoryIcons = {
  automation: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m6.8 15-3.5 2"/><path d="m20.7 17-3.5-2"/><path d="M6.8 9 3.3 7"/><path d="m20.7 7-3.5 2"/><circle cx="12" cy="12" r="4"/><path d="M12 18v4"/></svg>`,
  development: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  admin: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/></svg>`,
};

// Color classes for each category
const colorClasses = {
  emerald: {
    border: "hover:border-emerald-500/30",
    shadow: "hover:shadow-emerald-500/10",
    gradient: "from-emerald-500/5",
    iconBg: "bg-emerald-500/10 border-emerald-500/20 text-emerald-400",
    dot: "bg-emerald-500",
    toolHover: "hover:border-emerald-500/20 hover:bg-emerald-500/5",
  },
  blue: {
    border: "hover:border-blue-500/30",
    shadow: "hover:shadow-blue-500/10",
    gradient: "from-blue-500/5",
    iconBg: "bg-blue-500/10 border-blue-500/20 text-blue-400",
    dot: "bg-blue-500",
    toolHover: "hover:border-blue-500/20 hover:bg-blue-500/5",
  },
  purple: {
    border: "hover:border-purple-500/30",
    shadow: "hover:shadow-purple-500/10",
    gradient: "from-purple-500/5",
    iconBg: "bg-purple-500/10 border-purple-500/20 text-purple-400",
    dot: "bg-purple-500",
    toolHover: "hover:border-purple-500/20 hover:bg-purple-500/5",
  },
};

// Prepare categories array for easier iteration
const categories = [
  {
    key: "automation",
    ...techStack.automation,
    icon: categoryIcons.automation,
  },
  {
    key: "development",
    ...techStack.development,
    icon: categoryIcons.development,
  },
  { key: "admin", ...techStack.admin, icon: categoryIcons.admin },
];
---

<section
  class="py-24 border-b border-white/5 bg-neutral-950 relative overflow-hidden"
>
  <!-- Subtle Background Pattern -->
  <div
    class="absolute inset-0 opacity-[0.02]"
    style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Section Header -->
    <div class="scroll-fade mb-16 text-center max-w-3xl mx-auto">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full text-sm text-neutral-400 mb-6"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-blue-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"
          ></path><path d="M2 12l10 5 10-5"></path></svg
        >
        <span>{sectionContent.techStackSection.badge}</span>
      </div>
      <!-- Title -->
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        {sectionContent.techStackSection.title}
      </h2>
      <!-- Subtitle -->
      <p class="text-neutral-400 text-lg leading-relaxed">
        {sectionContent.techStackSection.subtitle}
      </p>
    </div>

    <!-- Stats Bar -->
    <div class="scroll-fade grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {
        stats.map((stat) => (
          <div class="text-center p-6 bg-white/[0.02] backdrop-blur-sm border border-white/5 rounded-2xl">
            <div
              class={`text-3xl md:text-4xl font-bold mb-1 ${stat.highlight ? "text-emerald-400" : "text-white"}`}
            >
              {stat.value}
            </div>
            <div class="text-sm text-neutral-500">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- Category Panels Grid -->
    <div class="scroll-fade grid grid-cols-1 lg:grid-cols-3 gap-8">
      {
        categories.map((category) => {
          const colors =
            colorClasses[category.color as keyof typeof colorClasses];
          return (
            <div
              class={`group relative p-8 rounded-3xl bg-gradient-to-b from-neutral-900/80 to-neutral-900/40 border border-white/5 ${colors.border} transition-all duration-500 hover:shadow-2xl ${colors.shadow}`}
            >
              {/* Hover Gradient Overlay */}
              <div
                class={`absolute inset-0 bg-gradient-to-br ${colors.gradient} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl`}
              />

              {/* Category Header */}
              <div class="relative flex items-center gap-4 mb-8">
                {/* Icon Container */}
                <div
                  class={`w-12 h-12 rounded-2xl ${colors.iconBg} border flex items-center justify-center`}
                >
                  <Fragment set:html={category.icon} />
                </div>
                {/* Title & Description */}
                <div>
                  <h3 class="text-lg font-semibold text-white">
                    {category.title}
                  </h3>
                  <p class="text-sm text-neutral-500">{category.description}</p>
                </div>
              </div>

              {/* Tools Grid */}
              <div class="relative grid grid-cols-1 sm:grid-cols-2 gap-3">
                {category.tools.map((tool) => (
                  <div
                    class={`flex items-center gap-3 p-3 rounded-xl bg-white/[0.02] border border-white/5 ${colors.toolHover} transition-all duration-300`}
                  >
                    <div class={`w-2 h-2 rounded-full ${colors.dot}`} />
                    <span class="text-sm font-medium text-neutral-300">
                      {tool}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- Trust Platforms Footer -->
    <div class="mt-16 text-center">
      <p class="text-sm text-neutral-500 mb-6">Trusted platforms I work with</p>
      <div
        class="flex flex-wrap justify-center items-center gap-8 opacity-50 grayscale hover:opacity-70 hover:grayscale-0 transition-all duration-500"
      >
        {
          trustPlatforms.map((platform) => (
            <div class="text-neutral-400 font-semibold text-lg">{platform}</div>
          ))
        }
      </div>
    </div>
  </div>
</section>
